# ─── Required ──────────────────────────────────────────────────────────────────
# Z.AI API key (primary LLM provider)
ZAI_API_KEY=

# ─── Optional ──────────────────────────────────────────────────────────────────
# Gemini API key (secondary provider)
GEMINI_API_KEY=

# External port for the OpenCode web endpoint (default: 4097)
OPENCODE_PORT=4097

# OpenCode CLI version to install in the container (default: 1.18.3)
# Check https://www.npmjs.com/package/opencode-ai for available versions
OPENCODE_VERSION=1.18.3

# ─── Workspace ─────────────────────────────────────────────────────────────────
# Primary host directory mounted as /workspace in the container
# For multiple directories, uncomment extra lines in docker-compose.yml
WORKSPACE_DIR=~/VSCODE

# ─── Git Identity ──────────────────────────────────────────────────────────────
# Used for git commits inside the container
GIT_USER_NAME=
GIT_USER_EMAIL=
