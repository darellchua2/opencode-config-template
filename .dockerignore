# Docker build context is the repo root (see docker-compose.yml).
# Keep the context lean and exclude secrets/dev artifacts.

# Secrets / env
.env
.env.*
!.env.example

# Version control
.git/
.gitignore
.gitmodules

# Dependencies
node_modules/
**/node_modules/
.venv/
venv/

# Dev / planning artifacts (not needed in the image)
PLANS/
LEARNINGS/
docs/
tests/
.vscode/
.idea/
.DS_Store

# CI / release config
.github/
.releaserc.json

# Python caches
*.pyc
__pycache__/

# Archived skills (keep image small)
opencode_app/.opencode/skills/_archived/
