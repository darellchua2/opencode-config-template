{
  "$schema": "https://opencode.ai/config.json",
  "model": "zai-coding-plan/glm-5",
  "default_agent": "build",
  "plugin": [
    "opencode-md-table-formatter",
    "opencode-dynamic-context-pruning",
    "opencode-supermemory",
    "opencode-notificator",
    "opencode-pty",
    "opencode-vibeguard",
    "opencode-claude-auth"
  ],
  "instructions": ["AGENTS.md"],
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      },
      "models": {
        "openai/gpt-oss-20b": {
          "name": "GPT-OSS 20B (local)"
        }
      }
    }
  },
  "mcp": {
    "atlassian": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://mcp.atlassian.com/v1/sse"
      ],
      "enabled": true
    },
    "web-reader": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_reader/mcp",
      "headers": {
        "Authorization": "Bearer {env:ZAI_API_KEY}"
      },
      "enabled": true
    },
    "web-search-prime": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_search_prime/mcp",
      "headers": {
        "Authorization": "Bearer {env:ZAI_API_KEY}"
      },
      "enabled": true
    },
    "zai-mcp-server": {
      "type": "local",
      "command": ["npx", "-y", "@z_ai/mcp-server"],
      "environment": {
        "Z_AI_API_KEY": "${env:ZAI_API_KEY}",
        "Z_AI_MODE": "ZAI"
      },
      "enabled": true
    },
    "zread": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/zread/mcp",
      "headers": {
        "Authorization": "Bearer {env:ZAI_API_KEY}"
      },
      "enabled": true
    },
    "google-bigquery": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://mcp.googleapis.com/bigquery/v1/sse"
      ],
      "environment": {
        "GOOGLE_APPLICATION_CREDENTIALS": "${env:GOOGLE_APPLICATION_CREDENTIALS}"
      },
      "enabled": false
    },
    "google-maps": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://mcp.googleapis.com/maps/v1/sse"
      ],
      "environment": {
        "GOOGLE_APPLICATION_CREDENTIALS": "${env:GOOGLE_APPLICATION_CREDENTIALS}"
      },
      "enabled": false
    },
    "google-gce": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://mcp.googleapis.com/compute/v1/sse"
      ],
      "environment": {
        "GOOGLE_APPLICATION_CREDENTIALS": "${env:GOOGLE_APPLICATION_CREDENTIALS}"
      },
      "enabled": false
    },
    "google-gke": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://mcp.googleapis.com/kubernetes-engine/v1/sse"
      ],
      "environment": {
        "GOOGLE_APPLICATION_CREDENTIALS": "${env:GOOGLE_APPLICATION_CREDENTIALS}"
      },
      "enabled": false
    }
  },
  "tools": {
    "atlassian*": false,
    "web-reader*": false,
    "web-search-prime*": false,
    "zai-mcp-server*": false,
    "zread*": false,
    "google-bigquery*": false,
    "google-maps*": false,
    "google-gce*": false,
    "google-gke*": false
  },
  "agent": {
    "build": {
      "permission": {
        "task": {
          "*": "allow"
        }
      }
    },
    "plan": {
      "permission": {
        "edit": "ask",
        "bash": "ask",
        "task": {
          "*": "allow"
        }
      }
    }
  }
}
